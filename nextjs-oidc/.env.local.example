# Override only when using a self-hosted instance (defaults to https://anonlog.in)
# AUTH_ANONLOGIN_ISSUER=https://your-instance.example.com

# OAuth client credentials — create these at /dashboard/clients
# Set redirect URI to: http://localhost:3000/api/auth/callback/anonlogin
AUTH_ANONLOGIN_ID=cid_your_client_id
AUTH_ANONLOGIN_SECRET=cs_your_client_secret

# Random secret used to encrypt the Auth.js session cookie.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=replace_with_random_secret
